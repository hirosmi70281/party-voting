# =============================================================================
# 2026 夏季夜 Vlog 團戰投票系統 — 環境變數
# =============================================================================
# 本地開發：把這個檔複製成 `.env.local`。Vercel production：在
# Vercel dashboard → Project Settings → Environment Variables 設定。
# 絕不要 commit `.env.local` 或任何含真實密鑰的檔。

# -----------------------------------------------------------------------------
# 活動品牌（可自由修改）
# -----------------------------------------------------------------------------
NEXT_PUBLIC_EVENT_NAME="2026 夏季夜｜Vlog 團戰"
NEXT_PUBLIC_EVENT_TAGLINE="投下你心中最強的兩支 Vlog"

# 公開網址（含 http/https）。產生投票 QR / 連結時用。
# 本地留空會自動用 request host（方便手機同網段測試）。
# Production 填你的 Vercel 網址，例：https://party-voting.vercel.app
NEXT_PUBLIC_BASE_URL=""

# -----------------------------------------------------------------------------
# 資料庫（KV）
# -----------------------------------------------------------------------------
# "memory"  → in-process（本地開發用，重啟即清空，免任何帳號）
# "upstash" → Upstash Redis（Vercel production 建議）
KV_PROVIDER="memory"

# 當 KV_PROVIDER="upstash" 時必填。
# 若用 Vercel Marketplace 整合 Upstash，Vercel 會自動注入 KV_REST_API_*，
# 兩組任一皆可（程式兩者都吃）。
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# 管理後台 /admin
# -----------------------------------------------------------------------------
# 管理密鑰。留空則 /admin 全部關閉（fail-closed）。
# 產生方式：  openssl rand -hex 16
ADMIN_SECRET=""
